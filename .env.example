PORT=3500
# Pon aquí el nombre exacto de Windows. Puedes verlo con: npm run list-printers
PRINTER_NAME=Brother QL-800
# Dominio permitido de tu sistema web. Ejemplo: https://app.koders.mx
ALLOWED_ORIGIN=http://localhost:5173,https://tu-dominio.com
BODY_LIMIT=5mb
LABEL_WIDTH_MM=100
LABEL_HEIGHT_MM=62
PRINT_SCALE=noscale
# Debe coincidir con un tamaño devuelto por: npm run list-printers
# Configura primero el driver Brother con DK 62mm Continuous / 62mm x Continuous.
